{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "worker_threads": 4,
    "max_connections": 10000
  },
  "rate_limit": {
    "enabled": true,
    "requests_per_second": 5,
    "burst_size": 5
  },
  "cors": {
    "enabled": true,
    "origins": ["*"]
  },
  "backends": [
    {"name": "users-service", "host": "localhost", "port": 3001, "weight": 1, "health_path": "/health", "group": "users"},
    {"name": "products-service", "host": "localhost", "port": 3002, "weight": 1, "health_path": "/health", "group": "products"},
    {"name": "orders-service", "host": "localhost", "port": 3003, "weight": 1, "health_path": "/health", "group": "orders"}
  ],
  "routes": [
    {"name": "users", "path": "/users.*", "backend": "users"},
    {"name": "products", "path": "/products.*", "backend": "products"},
    {"name": "orders", "path": "/orders.*", "backend": "orders"}
  ]
}
