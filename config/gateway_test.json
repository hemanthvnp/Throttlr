{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "worker_threads": 4,
    "max_connections": 10000,
    "jwt_secret": "test-secret-key-for-testing"
  },
  "rate_limit": {
    "enabled": true,
    "requests_per_second": 5,
    "burst_size": 5
  },
  "cors": {
    "enabled": true,
    "origins": ["http://example.com", "http://localhost:3000"],
    "methods": ["GET", "POST", "PUT", "DELETE"],
    "headers": ["Content-Type", "Authorization"],
    "max_age": 3600,
    "credentials": true
  },
  "backends": [
    {"name": "backend1", "host": "127.0.0.1", "port": 9001, "weight": 1},
    {"name": "backend2", "host": "127.0.0.1", "port": 9002, "weight": 2},
    {"name": "backend3", "host": "127.0.0.1", "port": 9003, "weight": 1}
  ],
  "routes": [
    {"name": "protected", "path": "/api/protected.*", "backend": "default", "auth_required": true},
    {"name": "public", "path": "/api/public.*", "backend": "default", "auth_required": false},
    {"name": "default", "path": "/.*", "backend": "default"}
  ],
  "admin": {
    "enabled": true,
    "path": "/_admin"
  }
}
