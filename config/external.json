{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "worker_threads": 2,
    "max_connections": 1000
  },
  "rate_limit": {
    "enabled": true,
    "requests": 100,
    "window_seconds": 60
  },
  "backends": [
    {
      "name": "jsonplaceholder",
      "host": "jsonplaceholder.typicode.com",
      "port": 80,
      "weight": 1,
      "health_path": "/posts/1",
      "group": "typicode"
    }
  ],
  "routes": [
    {
      "name": "posts",
      "path": "/posts.*",
      "backend": "typicode"
    }
  ]
}
