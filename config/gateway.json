{
  "server": {
    "host": "0.0.0.0",
    "port": 443,
    "tls_enabled": true,
    "tls_cert_file": "/opt/throttlr/certs/cert.pem",
    "tls_key_file": "/opt/throttlr/certs/key.pem",
    "jwt_secret": "my-secure-cloud-key"
  },
  "rate_limit": {"enabled": true, "requests": 5, "window_seconds": 60, "key_type": "path"},
  "backends": [
    {"name": "backend1", "host": "127.0.0.1", "port": 9001, "weight": 1},
    {"name": "backend2", "host": "127.0.0.1", "port": 9002, "weight": 1},
    {"name": "backend3", "host": "127.0.0.1", "port": 9003, "weight": 1}
  ],
  "routes": [
    {"name": "protected", "path": "/api/protected.*", "backend": "default", "auth_required": true},
    {"name": "public", "path": "/api/public.*", "backend": "default", "auth_required": false}
  ]
}
